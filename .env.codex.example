# Codex cloud runtime environment for tasks that need the app to boot.
# Do not copy .env.local into Codex cloud. It points at production services.
# Prefer staging or read-only credentials whenever possible.

# Required at runtime (see lib/env.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SESSION_SECRET=
CRON_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional for restricted Codex/cloud builds: tells
# `npm run codex:runtime-check` to use repo-local mocked Google Fonts
# responses instead of live Google Fonts fetches.
GOVERNADA_DISABLE_REMOTE_FONTS=1

# Recommended for app URLs and external integrations
NEXT_PUBLIC_SITE_URL=
KOIOS_API_KEY=
INNGEST_BASE_URL=
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
ADMIN_WALLETS=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
